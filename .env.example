# Copy this file to .env and customize as needed.
# .env is ignored by git — never commit secrets.

# Override the data directory (where expenses.json lives).
# Default: ~/.expense-tracker/
# EXPENSE_TRACKER_DATA_DIR=C:\Users\Avradip\Documents\my-expenses

# Override the full path to the expenses file.
# Takes precedence over EXPENSE_TRACKER_DATA_DIR.
# EXPENSE_TRACKER_FILE=C:\custom\path\expenses.json